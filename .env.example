# ==============================================================================
# CẤU HÌNH HỆ THỐNG CHUNG (GLOBAL SETTINGS)
# ==============================================================================
# Chạy lệnh 'id $USER' để xem PUID và PGID của bạn (thường là 1000)
PUID=1000
PGID=1000

# DNS Server (DNS server nội bộ trong dockitt_network)
DNS_SERVER=10.0.0.5

# Tên Docker Network (Phải khớp với network external đã tạo)
DOCKER_NETWORK_NAME=dockitt_network


# ==============================================================================
# 1. CẤU HÌNH GITEA (GIT SERVICE)
# ==============================================================================
# Database (PostgreSQL)
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=thay_doi_mat_khau_nay_123
GITEA_DB_NAME=gitea

# App Settings
GITEA_DOMAIN=git.yourdomain.com
GITEA_ROOT_URL=http://git.yourdomain.com/

# Static IPs
GITEA_DB_IP=10.0.0.20
GITEA_APP_IP=10.0.0.21


# ==============================================================================
# 2. CẤU HÌNH DRONE CI
# ==============================================================================
# Kết nối với Gitea (Lấy Client ID/Secret từ Gitea -> Settings -> Applications)
DRONE_GITEA_SERVER=http://git.yourdomain.com
DRONE_GITEA_CLIENT_ID=your_gitea_client_id_here
DRONE_GITEA_CLIENT_SECRET=your_gitea_client_secret_here

# RPC Secret: Dùng để Server và Runner xác thực với nhau.
# Mẹo: Chạy 'openssl rand -hex 16' để tạo chuỗi ngẫu nhiên.
DRONE_RPC_SECRET=thay_doi_chuoi_bi_mat_rpc_nay

# Server Settings
DRONE_SERVER_HOST=ci.yourdomain.com
DRONE_SERVER_PROTO=http

# Runner Settings
DRONE_RUNNER_CAPACITY=2
DRONE_RUNNER_NAME=my-docker-runner

# Static IPs
DRONE_SERVER_IP=10.0.0.30
DRONE_RUNNER_IP=10.0.0.31


# ==============================================================================
# 3. CẤU HÌNH BOOKSTACK (DOCUMENTATION)
# ==============================================================================
# Database (MariaDB)
MYSQL_ROOT_PASSWORD=root_secret_password
MYSQL_DATABASE=bookstackapp
MYSQL_USER=bookstack
MYSQL_PASSWORD=thay_doi_mat_khau_db_bookstack

# App Settings
# APP_KEY: Phải có độ dài 32 ký tự.
# Sau khi cài xong, bạn có thể chạy 'php artisan key:generate' trong container.
APP_KEY=base64:YZ4C6APWGy1e6+Iyq1dgaNDxvz3+ZCmYR4f0fnmkk68=
APP_URL=http://docs.yourdomain.com

# Kết nối DB
DB_HOST=10.0.0.40
DB_PORT=3306

# Static IPs
DB_STATIC_IP=10.0.0.40
APP_STATIC_IP=10.0.0.41
